    "@react-email/components": "^1.0.12",
    "hono": "^4.12.15",
    "pdf-lib": "^1.17.1",
    "react-email": "^6.0.0",
    "react-pdf": "^10.4.1",
    "react-signature-canvas": "^1.1.0-alpha.2",
    "recharts": "^3.8.1",
    "resend": "^6.12.2",
    "serve": "^14.2.6",
    "signature_pad": "^5.1.3"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1036.0",
    "@types/react-signature-canvas": "^1.0.7"
  }
}
